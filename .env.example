# Copie este arquivo para .env e preencha com suas chaves do Supabase
# Nunca envie o arquivo .env para o GitHub!

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_ANONIMA_AQUI

# Senha de acesso ao Painel Master (você define)
VITE_MASTER_KEY=sua_senha_secreta_aqui
